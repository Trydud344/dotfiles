{
    "layer": "top",
    "position": "top",
    "height": 30,
    "spacing": 0,
    
    "modules-left": [
        "hyprland/workspaces"
    ],
    
    "modules-center": [
        "hyprland/window"
    ],
    
    "modules-right": [
        "tray",
        "pulseaudio#output",
        "pulseaudio#input",
        "clock"
    ],

    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "active-only": false,
        "on-click": "activate",
        "format": "{name}"
    },
    
    "pulseaudio#output": {
        "format": "VOL {volume}%",
        "format-muted": "MUTED",
        "on-click": "pavucontrol"
    },
    
    "pulseaudio#input": {
        "format": "MIC {volume}%",
        "on-click": "pavucontrol"
    },
    
    "hyprland/window": {
        "format": "{}",
        "max-length": 50,
        "separate-outputs": true
    },
    
    "tray": {
        "icon-size": 16,
        "spacing": 10
    },
    
    "clock": {
        "format": "{:%H:%M  %b %d, %Y}"
    }
}
